        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "morgan": "^1.10.0",
        "pino": "^9.6.0",
        "pino-pretty": "^11.3.0",
        "prom-client": "^15.1.3",
        "swagger-jsdoc": "^6.2.8",
