{
    "name": "@ai-pandit/api",
    "version": "2.0.0",
    "description": "AI Pandit BTR Engine - Vedic Astrology Birth Time Rectification",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "dev:debug": "node --inspect -r tsx/esm src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "lint": "eslint src --ext .ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@ai-pandit/db": "*",
        "@ai-pandit/shared": "*",
        "@clerk/backend": "^1.26.2",
        "@libsql/client": "^0.17.0",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "date-fns": "^3.6.0",
        "dotenv": "^16.3.1",
        "drizzle-orm": "^0.45.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "pino": "^9.6.0",
        "pino-pretty": "^11.3.0",
        "swisseph-wasm": "^0.0.4",
        "uuid": "^9.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.14.0",
        "@types/supertest": "^6.0.3",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "@types/uuid": "^9.0.8",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "drizzle-kit": "^0.31.8",
        "eslint": "^8.57.0",
        "eslint-plugin-security": "^1.7.1",
        "supertest": "^7.2.2",
        "tsx": "^4.7.0",
        "typescript": "^5.4.5",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "keywords": [
        "vedic-astrology",
        "birth-time-rectification",
        "jyotish",
        "swiss-ephemeris",
        "ai"
    ]
}