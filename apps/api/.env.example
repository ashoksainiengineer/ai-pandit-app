# AI-Pandit API Environment Template
# =================================

# Server
NODE_ENV=production
PORT=3001
BACKEND_URL=https://your-api-domain.com
FRONTEND_URL=https://your-app-domain.com
# Additional allowed CORS origins (comma-separated)
# Include all your frontend URLs: production domains, Vercel deployments, localhost for development
ALLOWED_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com,https://your-vercel-frontend.vercel.app,http://localhost:3000,http://localhost:3001,http://localhost:5173

# Database (Turso)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# AI Configuration (OpenRouter/Fireworks)
AI_API_KEY=your-api-key
AI_MODEL=accounts/fireworks/models/deepseek-v3
AI_MODEL_REASONER=accounts/fireworks/models/deepseek-r1
AI_TIMEOUT_MS=120000
REQUEST_TIMEOUT_MS=300000

# Performance/Queue
MAX_CONCURRENT_SESSIONS=3
HEAP_THRESHOLD_GB=4
RSS_THRESHOLD_GB=6

# Security
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...
ENCRYPTION_SECRET=at-least-32-character-random-string
INTERNAL_API_KEY=your-internal-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
