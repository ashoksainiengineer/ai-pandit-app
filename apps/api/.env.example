# AI-Pandit API Environment Template
# =================================

# Server
NODE_ENV=production
PORT=3001
BACKEND_URL=https://your-api-domain.com
FRONTEND_URL=https://your-app-domain.com
# Additional allowed CORS origins (comma-separated)
# Include all your frontend URLs: production domains and localhost for development
ALLOWED_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com,http://localhost:3000,http://localhost:3001,http://localhost:5173

# Database (Neon Postgres)
NEON_DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require
POSTGRES_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# Redis (Upstash)
REDIS_URL=rediss://default:token@host.upstash.io:6379
REDIS_TLS=true

# AI Configuration
AI_API_KEY=your-api-key
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=deepseek-reasoner
AI_MODEL_REASONER=deepseek-reasoner
AI_TIMEOUT_MS=120000
REQUEST_TIMEOUT_MS=300000

# Performance/Queue
MAX_CONCURRENT_SESSIONS=3
HEAP_THRESHOLD_GB=4
RSS_THRESHOLD_GB=6

# Ephemeris
EPHEMERIS_PROVIDER=skyfield
EPHEMERIS_ALLOW_ALGORITHMIC_FALLBACK=false
EPHEMERIS_SERVICE_URL=http://localhost:8000
EPHEMERIS_SERVICE_TIMEOUT_MS=15000
EPHEMERIS_BATCH_SIZE=250
EPHEMERIS_HOUSE_SYSTEM=placidus

# Security
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...
ENCRYPTION_SECRET=at-least-32-character-random-string
INTERNAL_API_KEY=your-internal-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
