# Local Development Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# CLERK AUTHENTICATION (Required)
# Get from: https://dashboard.clerk.com
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
# URL where backend is running (for local dev, use localhost)
NEXT_PUBLIC_BACKEND_URL=http://localhost:7860

# =============================================================================
# DATABASE (Neon Postgres)
# Get from: https://neon.tech
# =============================================================================
NEON_DATABASE_URL=postgresql://user:password@localhost:5432/ai-pandit

# =============================================================================
# ENCRYPTION (Required - must be 32+ characters)
# Generate with: openssl rand -base64 32
# =============================================================================
ENCRYPTION_SECRET=your-encryption-secret-min-32-characters-long

# =============================================================================
# AI CONFIGURATION (OpenRouter)
# Get from: https://openrouter.ai/keys
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# =============================================================================
# OPTIONAL: Other Settings
# =============================================================================
# AI_MODEL=deepseek/deepseek-r1-0528
# AI_TIMEOUT_MS=180000
# MAX_CONCURRENT_SESSIONS=3
# MAX_ACTIVE_JOBS_PER_USER=2
# MAX_ACTIVE_JOBS_FREE=2
# MAX_ACTIVE_JOBS_PRO=5
# MAX_ACTIVE_JOBS_ENTERPRISE=12
# LOAD_SHED_QUEUE_DEPTH=80
# JOB_EXECUTION_MODE=external_worker
# WORKER_POLL_INTERVAL_MS=2000
# WORKER_DRAIN_TIMEOUT_MS=30000
# WORKER_RECOVERY_ALERT_THRESHOLD=1
# JOB_SYNC_POLL_INTERVAL_MS=2000
# REDIS_URL=redis://localhost:6379
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=ai-pandit-api
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com/v1/traces
# OTEL_TRACE_SAMPLE_RATIO=1
# TRACE_HEADER_NAME=x-trace-id
# SLO_WINDOW_MS=300000
# SLO_MIN_SAMPLE_SIZE=20
# SLO_ERROR_RATE_ALERT_PERCENT=5
# SLO_P95_LATENCY_ALERT_MS=5000
# REDIS_URL=redis://localhost:6379
# REDIS_TLS=false
# REDIS_QUEUE_NAME=ai-pandit:btr:jobs

# =============================================================================
# OPTIONAL: Deployed Stack Verification
# =============================================================================
# Use these when you want smoke/health verification against deployed Cloud Run.
# NEXT_PUBLIC_BACKEND_URL should point at the deployed API service.
# WORKER_HEALTH_URL should point at the deployed worker service.
# CLERK_BEARER_TOKEN should be a non-interactive test user's bearer token.
# WORKER_HEALTH_URL=https://worker-service-xxx.a.run.app
# CLERK_BEARER_TOKEN=eyJhbGciOi...
# SMOKE_BACKEND_URL=https://api-service-xxx.a.run.app
# SMOKE_API_BASE_URL=https://api-service-xxx.a.run.app
# SMOKE_PAYLOAD_PATH=apps/api/src/scripts/fixtures/smoke-job-payload.json
