# REQUIRED: Infrastructure
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
REDIS_URL=rediss://default:password@host:port
ENCRYPTION_SECRET=your-64-char-hex-secret

# REQUIRED: Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxx
CLERK_SECRET_KEY=sk_live_xxxx
CLERK_WEBHOOK_SECRET=whsec_xxxx

# REQUIRED: AI Configuration
AI_API_KEY=your-api-key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-reasoner

# OPTIONAL: AI Performance Tuning
AI_PARALLEL_CONCURRENCY=5
AI_STAGE2_MAX_TOKENS=32768
AI_STAGE4_MAX_TOKENS=32768
AI_STAGE6_MAX_TOKENS=32768

# REQUIRED: Service URLs
NEXT_PUBLIC_BACKEND_URL=https://api-service.xxxx.a.run.app
NEXT_PUBLIC_APP_URL=https://www.yourdomain.com
EPHEMERIS_SERVICE_URL=https://ephemeris-service.xxxx.a.run.app

# Environment
NODE_ENV=production
