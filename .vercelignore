# ═══════════════════════════════════════════════════════════════════
# Vercel Deploy — Only upload what apps/web needs to build
# Root Directory in Vercel dashboard = apps/web
# ═══════════════════════════════════════════════════════════════════

# Nothing from these top-level dirs
apps/api/
apps/worker/
services/
docs/
scripts/
e2e/
tests/
deploy/
local/
logs/
.claude/
.sisyphus/
.github/

# Build artifacts
node_modules/
.next/
dist/
coverage/
.turbo/
*.tsbuildinfo

# Test artifacts
**/__tests__/**
**/*.test.*
**/*.spec.*
playwright-report/
test-results/
stryker.config.mjs
playwright.config.*
vitest.config.*
vitest.workspace.*

# IDE / Tooling
.vscode/
.gemini/
.idx/
.cursorrules
.copilot*

# Configs not needed for build
.env*
!.env.production
!.env.production.example
.gitignore
.dockerignore
docker-compose*
Dockerfile
cloudbuild.yaml
vercel.json

# Docs and reports
*.md
!README.md
scorecard.png
a11y-report.json

# Temp files
*.log
*.sql
requeue_debug.txt
subjective_*

# Python ephemeris
*.bsp
services/ephemeris/
uv.lock
