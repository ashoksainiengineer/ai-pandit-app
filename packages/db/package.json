{
    "name": "@ai-pandit/db",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/drizzle.js",
    "types": "./dist/drizzle.d.ts",
    "exports": {
        ".": "./dist/drizzle.js",
        "./schema": "./dist/schema.js"
    },
    "scripts": {
        "build": "tsc",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@libsql/client": "^0.17.0",
        "drizzle-orm": "^0.45.1",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "@vitest/coverage-v8": "^4.0.18",
        "drizzle-kit": "^0.31.8",
        "typescript": "^5.4.5",
        "vitest": "^4.0.18"
    }
}
