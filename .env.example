# ==========================================
# AI-PANDIT BTR ENGINE - ENVIRONMENT VARIABLES
# ==========================================

# ==========================================
# CLERK AUTHENTICATION
# ==========================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Clerk Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ==========================================
# NEON POSTGRES DATABASE
# ==========================================
# Get these from https://neon.tech
NEON_DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require
# DATABASE_URL=postgresql://... (fallback)
# POSTGRES_URL=postgresql://... (fallback)

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NODE_ENV=production
PORT=8080

# ==========================================
# FRONTEND-BACKEND CONNECTION
# ==========================================
# Your deployed frontend URL (Cloud Run, custom domain, etc.)
FRONTEND_URL=https://your-frontend-domain.com
# Optional explicit public app URL for frontend runtime self-links
NEXT_PUBLIC_APP_URL=https://your-frontend-domain.com
# Your deployed API URL (used by frontend to connect to backend)
NEXT_PUBLIC_BACKEND_URL=https://your-api-domain.com
# Additional allowed CORS origins (comma-separated)
# Include all your frontend URLs: production domains and localhost for development
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com,http://localhost:3000,http://localhost:3001,http://localhost:5173

# ==========================================
# AI CONFIGURATION
# ==========================================
# Primary: DeepSeek (Recommended — see https://api-docs.deepseek.com/quick_start/pricing)
# Current models: deepseek-v4-flash (cost-efficient), deepseek-v4-pro (frontier)
# Legacy deepseek-chat/reasoner IDs RETIRE July 24, 2026 — migrate to v4-flash now
# Model IDs: deepseek-v4-flash | deepseek-v4-pro
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash

# Generic / Fallback (Standardized)
# The app uses AI_API_KEY → any OpenAI-compatible provider via AI_BASE_URL
AI_API_KEY=your_api_key
# For DeepSeek: https://api.deepseek.com
# For OpenRouter: https://openrouter.ai/api/v1
# For Groq: https://api.groq.com/openai/v1
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
# ==========================================
# ENCRYPTION (Required for data security)
# ==========================================
# Use a strong random string (64+ characters recommended)
# Must be the same for frontend and backend
ENCRYPTION_SECRET=your_encryption_secret_here_at_least_32_chars

# ==========================================
# RESOURCE MANAGEMENT
# ==========================================
NODE_OPTIONS=--max-old-space-size=256
MAX_CONCURRENT_SESSIONS=3
MAX_ACTIVE_JOBS_PER_USER=2
MAX_ACTIVE_JOBS_FREE=2
MAX_ACTIVE_JOBS_PRO=5
MAX_ACTIVE_JOBS_ENTERPRISE=12
LOAD_SHED_QUEUE_DEPTH=80

# Job queue execution — Redis BullMQ (REQUIRED: REDIS_URL below)
JOB_EXECUTION_MODE=external_worker
WORKER_POLL_INTERVAL_MS=2000
WORKER_DRAIN_TIMEOUT_MS=30000
WORKER_RECOVERY_ALERT_THRESHOLD=1
JOB_SYNC_POLL_INTERVAL_MS=2000

# Observability / tracing / SLO
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ai-pandit-api
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com/v1/traces
OTEL_TRACE_SAMPLE_RATIO=1
TRACE_HEADER_NAME=x-trace-id
SLO_WINDOW_MS=300000
SLO_MIN_SAMPLE_SIZE=20
SLO_ERROR_RATE_ALERT_PERCENT=5
SLO_P95_LATENCY_ALERT_MS=5000

# Redis queue settings (REQUIRED — job queue runs on Redis BullMQ)
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
REDIS_QUEUE_NAME=ai-pandit:btr:jobs

# ==========================================
# WARMUP CONFIGURATION (Prevent Cold Starts)
# ==========================================
# Enable periodic warmup pings (default: true)
ENABLE_WARMUP=true

# Warmup interval in minutes (default: 2)
WARMUP_INTERVAL_MINUTES=2

# Timeout for warmup requests in ms (default: 5000)
WARMUP_TIMEOUT_MS=5000

# ==========================================
# EPHEMERIS PROVIDER
# ==========================================
# skyfield = primary high-precision path
# algorithmic = built-in degraded mode
EPHEMERIS_PROVIDER=skyfield

# Allow degraded mode when the configured high-precision provider is unavailable
EPHEMERIS_ALLOW_ALGORITHMIC_FALLBACK=false

EPHEMERIS_SERVICE_URL=http://localhost:8000
EPHEMERIS_SERVICE_TIMEOUT_MS=15000
EPHEMERIS_BATCH_SIZE=250
EPHEMERIS_HOUSE_SYSTEM=placidus
