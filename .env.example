# ==========================================
# AI-PANDIT BTR ENGINE - ENVIRONMENT VARIABLES
# ==========================================

# ==========================================
# CLERK AUTHENTICATION
# ==========================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Clerk Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/rectify
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/rectify

# ==========================================
# TURSO DATABASE
# ==========================================
# Get these from https://turso.tech
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NODE_ENV=production
PORT=8080

# ==========================================
# AI CONFIGURATION
# ==========================================
# Primary: DeepSeek (Recommended)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-reasoner

# Generic (Standardized)
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-reasoner

# ==========================================
# RESOURCE MANAGEMENT
# ==========================================
NODE_OPTIONS=--max-old-space-size=256
MAX_CONCURRENT_SESSIONS=3

# ==========================================
# SWISS EPHEMERIS
# ==========================================
# Path to ephemeris data files
EPHE_PATH=./ephe