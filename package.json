{
    "name": "ai-pandit-monorepo",
    "private": true,
    "packageManager": "npm@10.8.0",
    "engines": {
        "node": ">=20.19.0"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "test": "turbo run test",
        "test:coverage": "turbo run test:coverage",
        "test:e2e": "npx playwright test",
        "test:e2e:ui": "npx playwright test --ui",
        "test:e2e:smoke": "npx playwright test e2e/smoke.spec.ts"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@playwright/test": "^1.58.2",
        "turbo": "^2.0.0"
    }
}