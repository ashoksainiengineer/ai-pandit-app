{
  "name": "ai-pandit-monorepo",
  "version": "2.0.0",
  "description": "Autonomous BTR Engine - Precision Vedic Astrology Birth Time Rectification powered by AI and NASA JPL data.",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:vercel:web": "npm --workspace @ai-pandit/shared run build && npm --workspace @ai-pandit/db run build && npm --workspace @ai-pandit/web run build:app",
    "test:deploy-config": "node ./scripts/verify-deploy-config.mjs",
    "dev": "turbo run dev",
    "dev:ephemeris": "sh ./services/ephemeris/scripts/dev.sh",
    "lint": "turbo run lint",
    "lint:strict": "npm -w @ai-pandit/api run lint:strict:phase1 && npm -w @ai-pandit/api run lint:strict:phase2 && npm -w @ai-pandit/web run lint",
    "test": "turbo run test",
    "test:full": "npm -w @ai-pandit/api run test:full",
    "test:full:ci": "npm -w @ai-pandit/api run test:full:deterministic",
    "test:with-summary": "npm run test 2>&1 | tee logs/test-latest.log && node scripts/summarize-test-log.mjs logs/test-latest.log logs/test-summary-latest",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:merge": "node scripts/merge-coverage-reports.js",
    "test:coverage:threshold": "npx nyc check-coverage --lines 80 --functions 80 --branches 75 --statements 80",
    "test:unit": "turbo run test:unit",
    "test:integration": "npm run test:api:integration && npm run test:db:integration && npm run test:ephemeris:integration",
    "test:api:integration": "vitest run --config apps/api/vitest.integration.config.ts",
    "test:db:integration": "vitest run --config packages/db/vitest.integration.config.ts",
    "test:ephemeris:integration": "vitest run --config services/ephemeris/vitest.config.ts",
    "test:contract": "npm -w @ai-pandit/shared run test:contract",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:smoke": "npx playwright test e2e/smoke.spec.ts",
    "test:e2e:full": "npx playwright test --project=chromium --project=firefox --project=webkit",
    "test:e2e:visual": "npx playwright test --project=visual",
    "test:e2e:a11y": "npx playwright test e2e/a11y.spec.ts",
    "test:performance": "npm run test:load && npm run test:stress && npm run test:capacity",
    "test:load": "npx k6 run tests/performance/load-test.js",
    "test:stress": "npx k6 run tests/performance/stress-test.js",
    "test:capacity": "npm -w @ai-pandit/api run capacity:validate",
    "test:security": "npm run test:security:api && npm run test:security:dependencies",
    "test:security:api": "npx zap-cli quick-scan --self-contained --start-options '-config api.disablekey=true' http://localhost:3000",
    "test:security:dependencies": "npx audit-ci --moderate",
    "test:security:snyk": "npx snyk test --all-projects",
    "test:mutation": "npx stryker run",
    "test:chaos": "npm -w @ai-pandit/api run chaos:resilience",
    "test:btr": "node test-runner.js",
    "test:btr:gandhi": "node test-runner.js --profile=gandhi",
    "test:btr:modi": "node test-runner.js --profile=modi",
    "test:watchdog": "npx playwright test e2e/analysis-watchdog.spec.ts",
    "test:ci": "npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e:smoke && npm run test:coverage:threshold",
    "test:ci:full": "npm run lint:strict && npm run test:full:ci && npm run test:e2e && npm run test:security:dependencies && npm run test:coverage:merge",
    "setup:ephemeris": "sh ./services/ephemeris/scripts/bootstrap.sh",
    "ephemeris:download-kernel": "sh ./services/ephemeris/scripts/download-kernel.sh",
    "deploy:cloudrun:api": "sh ./scripts/deploy-cloud-run.sh api",
    "deploy:cloudrun:ephemeris": "sh ./scripts/deploy-cloud-run.sh ephemeris",
    "deploy:cloudrun:web": "sh ./scripts/deploy-cloud-run.sh web",
    "deploy:cloudrun:worker": "sh ./scripts/deploy-cloud-run.sh worker",
    "deploy:staging:preflight": "sh ./scripts/staging-preflight.sh",
    "deploy:staging:sequence": "sh ./scripts/deploy-staging-sequence.sh",
    "deploy:cloudrun:idle-guards": "sh ./scripts/enforce-idle-cost-guards.sh",
    "deploy:cloudrun:prod-worker": "sh ./scripts/enable-production-worker-mode.sh",
    "cleanup:artifacts": "sh ./scripts/cleanup-artifact-images.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "audit-ci": "^7.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "nyc": "^18.0.0",
    "react-is": "^18.3.1",
    "snyk": "^1.1295.4",
    "turbo": "^2.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,css}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "next": "15.5.15"
  },
  "overrides": {
    "cross-spawn": "7.0.6"
  }
}
