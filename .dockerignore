# 🔱 GOD-TIER Docker Ignore for HF Spaces
# Minimize build context size for faster deployments

# Dependencies (installed in container)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Source and Build context
.git
.gitignore
.next
out
node_modules
dist
build
*.tsbuildinfo
.env
.env.*
.vercel
logs
*.log
.vscode
.idea
.DS_Store

# Tests (Keep on GitHub, exclude from build)
**/__tests__/**
**/coverage/**
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
