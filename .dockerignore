# ═══════════════════════════════════════════════════════════════════════════
# AI PANDIT - DOCKER CONTEXT HYGIENE (.dockerignore)
# Optimized for HF Spaces (Fast builds, small layers, zero secret leakage)
# ═══════════════════════════════════════════════════════════════════════════

# --- SOURCE CONTROL ---
.git
.gitignore
.dockerignore
.github/

# --- LOCAL DEPENDENCIES ---
node_modules/
**/node_modules/

# --- LOCAL BUILD ARTIFACTS ---
dist/
**/dist/
build/
.next/
**/.next/
out/
.turbo/
**/.turbo/
*.tsbuildinfo
.vercel/
.agents/

# --- SECRETS & LOCAL CONFIG ---
.env
.env.*
!.env.example
.clerk/
*.db
*.sqlite

# --- TOOLS & IDE ---
.vscode/
.idea/
.gemini/
.idx/
.cursorrules
.DS_Store
Thumbs.db

# --- TESTS & COVERAGE ---
__tests__/
**/__tests__/
tests/
**/tests/
coverage/
**/coverage/
playwright-report/
test-results/
.nyc_output
**/*.test.ts
**/*.test.tsx
**/*.test.js
**/*.test.jsx
**/*.spec.ts
**/*.spec.tsx

# --- APP SPECIFIC (BACKEND ONLY IMAGE) ---
apps/web/
ephe/*.se1  # Huge files are downloaded or copied in separate layers if needed

# --- MISC ---
*.log
npm-debug.log*
yarn-debug.log*
.eslintcache
.prettierrc
*.md  # Documentation not needed in production container
