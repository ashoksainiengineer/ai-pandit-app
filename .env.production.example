# Production Environment Variables
# 
# Copy this file to .env.production and fill in your real production values.
# Then run: sh scripts/sync-production-config.sh --env-file .env.production --apply
#
# PLATFORM SPLIT:
# - Vercel (apps/web): Only needs Vercel-specific variables
# - Cloud Run (api/worker/ephemeris): Needs backend service variables
#
# ═════════════════════════════════════════════════════════════════════════════
# VERCEL (Frontend Web App) - Required Variables
# ═════════════════════════════════════════════════════════════════════════════

# Clerk Authentication (Browser + Server)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_SECRET_KEY=sk_live_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me

# Frontend Configuration
NEXT_PUBLIC_APP_URL=https://aipandit.app
NEXT_PUBLIC_BACKEND_URL=https://api-service-7tjuxigfoq-as.a.run.app

# Database (Required for Clerk webhook route on Vercel)
NEON_DATABASE_URL=postgresql://username:password@ep-your-neon-host.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Security
ENCRYPTION_SECRET=replace_with_a_64_plus_character_secret_value

# ═════════════════════════════════════════════════════════════════════════════
# CLOUD RUN (Backend Services) - Required Variables
# ═════════════════════════════════════════════════════════════════════════════

# AI Provider Configuration - DeepSeek v4 Flash
AI_API_KEY=replace_with_deepseek_api_key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash

# Cache & Queue (Upstash Redis - FREE TIER)
# 1. Sign up at https://console.upstash.com (free tier: 10K commands/day)
# 2. Create Redis database in Singapore (ap-southeast-1) - same region as Cloud Run
# 3. Copy the rediss:// connection URL
#
# IMPORTANT: Upstash free tier limits:
# - 10,000 commands per day
# - 256 MB storage
# - 1 database
# - Perfect for startups, upgrade when you hit limits
#
# For production with 1000+ users, switch to paid tier ($0.20/100K commands)
REDIS_URL=rediss://default:password@your-upstash-endpoint.upstash.io:6379
REDIS_TLS=true
REDIS_QUEUE_NAME=ai-pandit:btr:jobs

# Job Queue — Redis BullMQ (required for production)
# All job queuing, claiming, and retry scheduling runs through Upstash Redis.
REDIS_URL=rediss://default:password@your-upstash-endpoint.upstash.io:6379
REDIS_TLS=true
REDIS_QUEUE_NAME=ai-pandit:btr:jobs

# Redis Event Store (optional - enables persistent SSE event buffers)
# Set to true if you want Redis-backed event storage instead of in-memory
USE_REDIS_EVENTS=false
REDIS_URL=rediss://default:password@your-upstash-endpoint.upstash.io:6379

# Ephemeris Service
EPHEMERIS_SERVICE_URL=https://ephemeris-service-7tjuxigfoq-as.a.run.app
EPHEMERIS_SERVICE_TIMEOUT_MS=20000
EPHEMERIS_BATCH_SIZE=250

# ═════════════════════════════════════════════════════════════════════════════
# GCP Project Configuration
# ═════════════════════════════════════════════════════════════════════════════

GCP_PROJECT_ID=ai-pandit-489913
GOOGLE_CLOUD_PROJECT=ai-pandit-489913
CLOUD_RUN_REGION=asia-southeast1
ARTIFACT_REGISTRY_REPO=ai-pandit
APP_REGION=asia-southeast1

# ═════════════════════════════════════════════════════════════════════════════
# Backend Service Configuration (Cloud Run)
# ═════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
FRONTEND_URL=https://aipandit.app
BACKEND_URL=https://api-service-7tjuxigfoq-as.a.run.app
ALLOWED_ORIGINS=https://aipandit.app,https://www.aipandit.app

# Ephemeris Settings
EPHEMERIS_PROVIDER=skyfield
EPHEMERIS_ALLOW_ALGORITHMIC_FALLBACK=false
EPHEMERIS_HOUSE_SYSTEM=placidus

# Queue Configuration (Redis BullMQ — see REDIS_URL above)
JOB_EXECUTION_MODE=external_worker
JOB_EXECUTION_MODE=external_worker
WORKER_POLL_INTERVAL_MS=2000
WORKER_DRAIN_TIMEOUT_MS=30000
JOB_SYNC_POLL_INTERVAL_MS=2000
USE_ASYNC_JOB_PIPELINE=true
USE_NEW_STREAM_PATH=true

# Limits
MAX_CONCURRENT_SESSIONS=3
MAX_ACTIVE_JOBS_PER_USER=2
