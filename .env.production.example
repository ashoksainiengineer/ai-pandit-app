APP_REGION=asia-southeast1

NEON_DATABASE_URL=postgresql://username:password@ep-your-neon-host.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
REDIS_URL=rediss://default:password@your-upstash-endpoint.upstash.io:6379
AI_API_KEY=replace_with_ai_api_key
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=openai/gpt-oss-120b
ENCRYPTION_SECRET=replace_with_a_64_plus_character_secret_value
CLERK_SECRET_KEY=sk_live_replace_me
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me

FRONTEND_URL=https://aipandit.app
NEXT_PUBLIC_APP_URL=https://aipandit.app
BACKEND_URL=https://api-service-7tjuxigfoq-as.a.run.app
NEXT_PUBLIC_BACKEND_URL=https://api-service-7tjuxigfoq-as.a.run.app
ALLOWED_ORIGINS=https://aipandit.app,https://www.aipandit.app

EPHEMERIS_PROVIDER=skyfield
EPHEMERIS_ALLOW_ALGORITHMIC_FALLBACK=false
