# =============================================================================
# AI PANDIT - COMPREHENSIVE .gitignore
# Following industry best practices
# =============================================================================

# --- DEPENDENCIES ---
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
yarn.lock
pnpm-lock.yaml

# --- ENVIRONMENT & SECRETS ---
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env*.local
.clerk/
*.pem
*.key
secrets/
config/secrets/

# --- DATABASE FILES ---
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# --- BUILD OUTPUTS ---
dist/
build/
.next/
out/
.nuxt/
.turbo/
*.tsbuildinfo
.vercel/
.netlify/
.agents/
.cache/
.parcel-cache/

# --- LOGS & DIAGNOSTICS ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.stylelintcache
.prettiercache
*.pid
*.seed
*.pid.lock

# --- TEST ARTIFACTS ---
coverage/
playwright-report/
test-results/
.nyc_output
.vitest-reports/
*.test.ts.snap
*.test.tsx.snap
__snapshots__/

# --- SYSTEM & IDE ---
.DS_Store
Thumbs.db
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.project
.classpath
*.sublime-workspace
*.sublime-project

# --- CLOUD & PLATFORM ---
.gemini/
.idx/
.firebase/
.firebaserc

# --- BACKUP FILES ---
*.backup
*.bak
*.old
*.original
*.swp
*.swo
*~

# --- APP SPECIFIC (NON-SOURCE) ---
