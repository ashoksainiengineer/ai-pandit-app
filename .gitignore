apps/api/ephe/*.se1
!apps/api/ephe/README.md
!apps/api/ephe/.gitkeep

# Swiss Ephemeris (legacy - removed from project)
sweph.tar.gz
*.eph

# Skyfield data
data/*.bsp
data/*.bpc
data/*.tpc
data/*.naif
data/*.txt

services/ephemeris/data/*.bsp
services/ephemeris/data/*.bpc
services/ephemeris/data/*.tpc
services/ephemeris/data/*.naif
services/ephemeris/data/*.txt

# --- PYTHON (EPHEMERIS SERVICE) ---
services/ephemeris/.venv/
services/ephemeris/__pycache__/
