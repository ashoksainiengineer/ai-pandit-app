.next/
.turbo/
out/
build/
*.tsbuildinfo
*.js.map
*.d.ts.map
.eslintcache
.stylelintcache
.prettiercache

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
