services/ephemeric/*$py.class
services/ephemeris/.pytest_cache/
services/ephemeris/.mypy_cache/
services/ephemeris/.ruff_cache/
services/ephemeris/.coverage
services/ephemeris/.coverage.*
services/ephemeris/htmlcov/
services/ephemeris/dist/
services/ephemeris/*.egg-info/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
.eggs/

# --- DOCKER ---
Dockerfile.local
docker-compose.override.yml
.docker/

# --- TYPESCRIPT ---
*.js.map
*.d.ts.map

# --- MISC ---
*.tgz
*.tar.gz
*.zip

# --- TEMPORARY FILES ---
tmp/
temp/
tmp.*
*.tmp

# --- SCRATCH & DEBUG (keep these out of git) ---
scratch/
scratch.*
debug/
debug-*.ts
debug-*.js
test-*.ts
test-*.js
check-*.ts
check-*.js
verify-*.ts
verify-*.js
apps/api/test-*.ts
check-*.ts
apps/api/src/check-*.ts
check-*.ts
apps/api/src/debug-*.ts
debug-*.ts
apps/api/src/test-*.ts
test-*.ts
apps/api/src/requeue-*.ts
requeue-*.ts
apps/api/src/scripts/requeue_debug.txt
requeue_debug.txt
logs/debug-analysis.log
debug-analysis.log
verify-production.ts
!apps/api/src/utils/debug-logger.ts
!apps/api/src/routes/debug-analysis.ts

